[Unit]
Description=Lemonade llama-server (gfx1151 ROCm)
After=network.target
Wants=network.target

[Service]
Type=simple
User=miko_node_001
Group=miko_node_001
ExecStart=/home/miko_node_001/lemonade-b1195/llama-server \
  -m /mnt/models/Qwen3.5-35B-A3B-UD-Q4_K_XL.gguf \
  -ngl 99 \
  --no-mmap \
  -fa on \
  --ctx-size 32768 \
  --cache-type-k q4_0 \
  --cache-type-v q4_0 \
  --jinja --chat-template-kwargs '{"enable_thinking":false}' --reasoning-budget 0 \
  --host 0.0.0.0 \
  --port 11435 \
  -np 1 \
  --temp 0.6 \
  --top-k 20 \
  --top-p 0.95 \
  --min-p 0.0
Restart=on-failure
RestartSec=10
Environment="HSA_OVERRIDE_GFX_VERSION=11.5.1"
Environment="HIP_VISIBLE_DEVICES=0"
Environment="ROCR_VISIBLE_DEVICES=0"

[Install]
WantedBy=multi-user.target
